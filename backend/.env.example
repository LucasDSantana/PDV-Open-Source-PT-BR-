# ==================================
# PDV Open Source - Variáveis de Ambiente (EXEMPLO)
# ==================================
# Copie este arquivo para .env e preencha os valores

# Porta do servidor backend
PORT=3002

# ── AbacatePay API (somente PIX) ────
# Obtenha sua chave em: https://app.abacatepay.com
ABACATEPAY_API_KEY=sua_chave_api_aqui
ABACATEPAY_API_URL=https://api.abacatepay.com/v1

# URL pública do seu sistema
APP_URL=http://localhost:5174

# ── TEF / PINPAD (Cartão Crédito/Débito) ────
# Habilita integração com maquininha física
TEF_HABILITADO=true
# Provedor: simulado (dev), sitef, paygo, stone
TEF_PROVEDOR=simulado
# IP do terminal TEF na rede local
TEF_ENDERECO_IP=127.0.0.1
# Porta de comunicação do TEF
TEF_PORTA=60906
# ID da loja/estabelecimento
TEF_LOJA_ID=PDV001

# ── Configurações de Pagamento ──────
# Porcentagem cobrada em cima da venda (Split / Taxa de Serviço)
TAXA_SERVICO_PERCENTUAL=0
